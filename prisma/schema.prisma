generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////
// ENUMS
//////////////////////

enum AuthProvider {
  CREDENTIALS
  GOOGLE
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum TutorStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum BookingStatus {
  REQUESTED
  PAYMENT_PENDING
  READY
  COMPLETED
  CANCELLED
  EXPIRED
  REJECTED
}

enum PayMode {
  HALF
  FULL
}

enum SessionType {
  ONE_TO_ONE
  GROUP
}

enum AvailabilityType {
  ONE_TO_ONE
  GROUP
}

enum PackageType {
  SINGLE_SESSION
  MONTHLY_PACKAGE
}

enum NotificationType {
  BOOKING_REQUESTED
  BOOKING_ACCEPTED
  BOOKING_REJECTED

  PAYMENT_REQUIRED
  PAYMENT_CONFIRMED
  PAYMENT_FAILED

  SESSION_SCHEDULED
  SESSION_LINK_SHARED
  SESSION_REMINDER
  SESSION_CANCELLED
  SESSION_RESCHEDULED
  SESSION_COMPLETED

  MESSAGE_RECEIVED
  SYSTEM_ANNOUNCEMENT
}

enum PaymentStatus {
  PENDING
  HALF_PAID
  FULL_PAID
  REMAINING_DUE  
  REFUNDED 
  FAILED
}

enum BookingPaymentStatus {
  UNPAID
  PARTIALLY_PAID
  FULLY_PAID
}

enum PaymentGateway {
  ESEWA
  KHALTI
}

enum ConversationType {
  TUTOR_SESSION
  THRIFT
}

enum CancelledBy {
  STUDENT
  TUTOR
}

enum RefundStatus {
  NONE
  CREDITED
  NOT_ELIGIBLE
}

enum WalletTransactionType {
  CREDIT
  DEBIT
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
}

//////////////////////
// USER
//////////////////////

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String       @unique
  password      String?
  phone         String?
  grade         String?
  image         String?
  emailVerified DateTime?
  verifyCode    String?
  verifyExpiry  DateTime?
  authProvider  AuthProvider @default(CREDENTIALS)
  status        UserStatus   @default(ACTIVE)

  resetToken   String?
  resetExpires DateTime?

  walletBalance      Int                 @default(0)
  walletTransactions WalletTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts            Account[]
  sessions            Session[]
  thriftItems         ThriftItem[]
  reviews             Review[]
  bookings            Booking[]
  notifications       Notification[]
  sentMessages        Message[]      @relation("UserMessages")
  conversations       Conversation[] @relation("StudentConvos")
  conversationsThrift Conversation[] @relation("ThriftUserConvos")

suspendedBy String? // "ADMIN" | "USER"
unpaidStrikeCount Int     @default(0)

notifyBooking  Boolean @default(true)
notifyPayment  Boolean @default(true)
notifyMessage  Boolean @default(true)
}

//////////////////////
// TUTOR
//////////////////////

model Tutor {
  id       String  @id @default(cuid())
  name     String
  email    String  @unique
  phone    String
  password String?

  photo      String?
  bio        String?
  experience String?
  cvUrl      String?
  idUrl      String?
  rate       Int?

  status TutorStatus @default(PENDING)

  walletBalance Int @default(0)
  walletTransactions TutorWalletTransaction[] 

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subjects       TutorSubject[]
  reviews        Review[]
  bookings       Booking[]
  availabilities TutorAvailability[]
  sentMessages   Message[]      @relation("TutorMessages")
  conversations  Conversation[] @relation("TutorConvos")
  earnings       TutorEarning[]
  withdrawals    Withdrawal[]
  notifications  Notification[]

  averageRating Float @default(0)
  reviewCount   Int   @default(0)

  emailVerified    Boolean   @default(false)
  verificationCode String?
  codeExpiresAt    DateTime?

  rejectionReason  String?
  suspensionReason String?
}

model TutorSubject {
  id      String  @id @default(cuid())
  tutorId String
  subject String
  level   String?

  tutor Tutor @relation(fields: [tutorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([tutorId, subject, level])
  @@index([tutorId])
}

model TutorEarning {
  id        String   @id @default(uuid())
  tutorId   String
  bookingId String
  amount    Float
  type      String
  createdAt DateTime @default(now())

  tutor   Tutor   @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([tutorId])
  @@unique([bookingId, type])
}

//////////////////////
// TUTOR AVAILABILITY
//////////////////////

model TutorAvailability {
  id      String @id @default(cuid())
  tutorId String

  subject String
  level   String?

  date        DateTime
  startTime   String
  endTime     String
  durationMin Int

  sessionType  AvailabilityType
  maxStudents  Int?
  currentCount Int              @default(0)
  isActive     Boolean          @default(true)

  tutor    Tutor     @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  bookings Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tutorId, date])
  @@index([tutorId, subject, level])
  @@index([isActive])
}

//////////////////////
// BOOKINGS
//////////////////////

model Booking {
  id String @id @default(cuid())

  studentId      String
  tutorId        String
  availabilityId String
  reviews Review[]

  student      User              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  tutor        Tutor             @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  availability TutorAvailability @relation(fields: [availabilityId], references: [id], onDelete: Cascade)

  sessionType SessionType
  subject     String
  level       String?

  bookingDate DateTime
  startTime   DateTime
  endTime     DateTime
  durationMin Int

  tutorEarnings TutorEarning[]
   tutorPaid      Boolean   @default(false)
  tutorPaidAt    DateTime?

  maxStudents  Int?
  currentCount Int  @default(1)

  packageType   PackageType @default(SINGLE_SESSION)
  packageMonths Int?

  hourlyRate  Int
  totalAmount Int

  note          String?
  notifications Notification[]

  status       BookingStatus @default(REQUESTED)
  tutorSeen    Boolean       @default(false)
  cancelledBy  CancelledBy?
  cancelReason String?

  refundAmount Int          @default(0)
  refundStatus RefundStatus @default(NONE)
  refundedAt   DateTime?

  payments      Payment[]
  paymentStatus BookingPaymentStatus @default(UNPAID)
  paymentDueAt DateTime?

  meetingRoom    String?
  sessionStarted Boolean   @default(false)
  startedAt      DateTime?
  endedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  walletTransactions WalletTransaction[]

  @@index([studentId])
  @@index([tutorId])
  @@index([availabilityId])
  @@index([tutorId, startTime, endTime])
  @@index([studentId, startTime, endTime])
}

//////////////////////
// PAYMENT
//////////////////////

model Payment {
  id String @id @default(cuid())

  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  gateway         PaymentGateway
  transactionUuid String         @unique
  amount          Int
  payMode         PayMode
  paidAmount      Int

  status PaymentStatus @default(PENDING)

  refId       String?
  rawResponse Json?

  adminCommission Int?
  tutorEarning    Int?
  tutorPaid       Boolean   @default(false)
  tutorPaidAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bookingId])
}

//////////////////////
// REVIEWS
//////////////////////

model Review {
  id        String   @id @default(cuid())

  tutorId   String
  userId    String
bookingId String

  rating    Int
  comment   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tutor   Tutor   @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)


  @@unique([bookingId]) 
}

//////////////////////
// THRIFT ITEMS
//////////////////////

model ThriftItem {
  id        String  @id @default(cuid())
  title     String
  subject   String?
  condition String?
  price     Int
  contact   String
  image     String?
  grade     String?
  location String?

  isSold   Boolean @default(false)
  isActive Boolean @default(true)

  isReported   Boolean  @default(false)
  reportReason String?

  sellerId String
  seller   User   @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([isSold])
  @@index([isActive])
  @@index([isReported])
}

//////////////////////
// NEXTAUTH
//////////////////////

model Account {
  id                String @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String

  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  oauth_token_secret String?
  oauth_token        String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

//////////////////////
// NOTIFICATION
//////////////////////

model Notification {
  id String @id @default(cuid())

  userId  String?
  tutorId String?

  isForAdmin    Boolean @default(false)
  adminCategory String?

  title   String
  message String
  type    NotificationType

  bookingId String?
  sessionId String?
  studentId String?

  actionUrl   String?
  actionLabel String?

  isRead Boolean @default(false)

  createdAt DateTime @default(now())

  user    User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tutor   Tutor?   @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tutorId])
  @@index([bookingId])
  @@index([isForAdmin])
}

//////////////////////
// MESSAGE
//////////////////////

model Conversation {
  id String @id @default(cuid())

  studentId String
  student   User   @relation("StudentConvos", fields: [studentId], references: [id], onDelete: Cascade)

  type ConversationType

  tutorId String?
  tutor   Tutor?  @relation("TutorConvos", fields: [tutorId], references: [id], onDelete: Cascade)

  thriftUserId String?
  thriftUser   User?   @relation("ThriftUserConvos", fields: [thriftUserId], references: [id], onDelete: Cascade)

  thriftItemId String?

  messages Message[]

  createdAt DateTime @default(now())

  @@unique([studentId, tutorId], map: "unique_tutor_chat")
  @@unique([studentId, thriftUserId, thriftItemId], map: "unique_thrift_chat")
}

model Message {
  id String @id @default(cuid())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  senderUserId  String?
  senderTutorId String?

  senderUser  User?  @relation("UserMessages", fields: [senderUserId], references: [id], onDelete: Cascade)
  senderTutor Tutor? @relation("TutorMessages", fields: [senderTutorId], references: [id], onDelete: Cascade)

  content String
  isRead  Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([conversationId])
}

//////////////////////
// WALLET
//////////////////////

model WalletTransaction {
  id        String                @id @default(uuid())
  userId    String
  amount    Float
  type      WalletTransactionType
  reason    String
  bookingId String?
  createdAt DateTime              @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  booking   Booking? @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([bookingId])
}
model TutorWalletTransaction {
  id        String                @id @default(uuid())
  tutorId   String
  amount    Float
  type      WalletTransactionType
  reason    String
  bookingId String?
  createdAt DateTime              @default(now())

  tutor Tutor @relation(fields: [tutorId], references: [id], onDelete: Cascade)

  @@index([tutorId])
  @@index([bookingId])
}

model Withdrawal {
  id        String           @id @default(cuid())
  tutorId   String
  amount    Int
  status    WithdrawalStatus @default(PENDING)
  createdAt DateTime         @default(now())

  tutor Tutor @relation(fields: [tutorId], references: [id], onDelete: Cascade)

  @@index([tutorId])
}

//////////////////////
// ADMIN
//////////////////////

model Admin {
  id       String @id @default(cuid())
  email    String @unique
  password String
  role     String @default("ADMIN")
}
